  {
    "id": "sec_filing_fetch",
    "summary": "Fetch narrative sections from a company’s SEC filing by fiscal year and period.",
    "args": [
      {
        "name": "ticker",
        "required": true,
        "variadic": false,
        "description": "Stock ticker (e.g., AAPL)"
      }
    ],
    "options": [
      {
        "flags": "--year <year>",
        "description": "Fiscal year (e.g., 2024)",
        "required": true,
        "takesValue": true,
        "negate": false
      },
      {
        "flags": "--period <period>",
        "description": "Fiscal period",
        "required": true,
        "takesValue": true,
        "negate": false,
        "choices": ["FY", "Q1", "Q2", "Q3", "Q4"]
      },
      {
        "flags": "--sections <sections>",
        "description": "Comma-separated section names (e.g., risk_factors,business)",
        "required": false,
        "takesValue": true,
        "negate": false,
        "default": "risk_factors"
      },
      {
        "flags": "--format <format>",
        "description": "Output format",
        "required": false,
        "takesValue": true,
        "negate": false,
        "choices": ["text", "json", "yaml"],
        "default": "text"
      }
    ]
  },
  {
    "id": "sec_filing_diff",
    "summary": "Compare two of a company’s SEC filings and report section-level changes.",
    "args": [
      {
        "name": "ticker",
        "required": true,
        "variadic": false,
        "description": "Stock ticker (e.g., AAPL)"
      }
    ],
    "options": [
      {
        "flags": "--base <year:period>",
        "description": "Earlier filing as YEAR:PERIOD (e.g., 2023:FY)",
        "required": true,
        "takesValue": true,
        "negate": false
      },
      {
        "flags": "--compare <year:period>",
        "description": "Later filing as YEAR:PERIOD (e.g., 2024:FY)",
        "required": true,
        "takesValue": true,
        "negate": false
      },
      {
        "flags": "--sections <sections>",
        "description": "Comma-separated section names (e.g., risk_factors,mda)",
        "required": false,
        "takesValue": true,
        "negate": false,
        "default": "risk_factors,mda,business,legal"
      },
      {
        "flags": "--mode <mode>",
        "description": "Output mode",
        "required": false,
        "takesValue": true,
        "negate": false,
        "choices": ["diff", "raw", "summary"],
        "default": "diff"
      },
      {
        "flags": "--no-qa",
        "description": "Skip the QA fidelity review",
        "required": false,
        "takesValue": false,
        "negate": true
      },
      {
        "flags": "--format <format>",
        "description": "Render API result as json or yaml",
        "required": false,
        "takesValue": true,
        "negate": false,
        "choices": ["json", "yaml"]
      }
    ]
  },
