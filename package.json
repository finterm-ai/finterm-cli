{
  "name": "finterm-cli-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:install": "pnpm --filter finterm test:install",
    "test:uninstall": "pnpm --filter finterm test:uninstall",
    "public:check": "node scripts/check-public-boundary.mjs",
    "publint": "pnpm -r publint",
    "format": "prettier --write --log-level warn .",
    "format:check": "prettier --check --log-level warn .",
    "lint": "eslint . --fix && pnpm typecheck && eslint . --max-warnings 0",
    "lint:check": "pnpm typecheck && eslint . --max-warnings 0",
    "precommit": "pnpm format && pnpm lint && pnpm test && pnpm build",
    "ci": "pnpm format:check && pnpm lint:check && pnpm test && pnpm build && pnpm publint && pnpm --filter finterm test:pack && pnpm public:check",
    "finterm": "tsx packages/finterm-cli/src/cli/bin.ts",
    "finterm:bin": "pnpm --filter finterm build && node packages/finterm-cli/dist/bin-bootstrap.cjs",
    "upgrade:check": "ncu --format group",
    "upgrade": "ncu --target minor -u && pnpm install && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@finterm/dataroom-cli": "workspace:^0.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.19.11",
    "dataroom": "workspace:^0.0.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "npm-check-updates": "^17.1.18",
    "prettier": "^3.8.1",
    "publint": "^0.3.17",
    "tsdown": "0.20.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^3.2.4"
  }
}
